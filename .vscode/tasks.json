{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Next.js",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "next dev",
          "endsPattern": "Local:.*localhost"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Flutter: Hot Reload (web)",
      "type": "shell",
      "command": "flutter run -d web-server --web-port=4444 --web-hostname=localhost --dart-define=API_BASE_URL=http://localhost:3000",
      "options": {
        "cwd": "${workspaceFolder}/amistosos_flutter",
        "env": {
          "PATH": "C:\\flutter\\bin;${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Launching lib",
          "endsPattern": "Flutter run key commands"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🚀 Iniciar todo",
      "dependsOn": ["Backend: Next.js", "Flutter: Hot Reload (web)"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
